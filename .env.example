APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=zendesk_ai
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (required for password reset emails; use "log" to write to storage/logs in dev)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="tecDESK"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Admin user (created by AdminUserSeeder)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password

# Default password for users created from Zendesk sync (zendesk:sync-users-app)
SYNC_USER_DEFAULT_PASSWORD=changeme

# Zendesk API
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
ZENDESK_RATE_LIMIT_PER_MINUTE=400
# Only sync tickets from these requesters. Email ou ZD ID (Admin > Pessoas > usuário > ID na URL).
# ZENDESK_FILTER_REQUESTER_EMAILS=caixaandracentro@andrauniformes.com.br
# ZENDESK_FILTER_REQUESTER_ZD_IDS=123456789
# Exclude tickets with these statuses (comma-separated)
ZENDESK_EXCLUDE_STATUSES=closed
# Days since last update to flag as "old" / "too old" (open tickets only)
# ZENDESK_TICKET_AGE_OLD_DAYS=3
# ZENDESK_TICKET_AGE_TOO_OLD_DAYS=7
# Priority order for sorting (comma-separated, first = highest)
# ZENDESK_PRIORITY_ORDER=urgent,high,normal,low
# Set to false for local dev when PHP has no CA bundle (Windows cURL error 60)
ZENDESK_SSL_VERIFY=true

# OpenAI (for AI classification and embeddings)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
# Set to false for local dev when PHP has no CA bundle (Windows cURL error 60)
OPENAI_SSL_VERIFY=true
